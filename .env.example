# ===========================================
# VoiceDraw Agent — 环境变量模板
# 复制为 .env 并填入真实值。.env 已在 .gitignore 中排除。
# ===========================================

# -------- 七牛云 --------
# DeepSeek 大模型 (必需)
QINIU_DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
QINIU_DEEPSEEK_BASE_URL=https://api.qiniu.com/v1

# ASR 语音识别 (可选 — Web Speech 不可用时使用)
QINIU_ASR_ACCESS_KEY=xxxxxxxxxxxxxxxx
QINIU_ASR_SECRET_KEY=xxxxxxxxxxxxxxxx

# TTS 语音合成 (可选 — SpeechSynthesis 不可用时使用)
QINIU_TTS_ACCESS_KEY=xxxxxxxxxxxxxxxx
QINIU_TTS_SECRET_KEY=xxxxxxxxxxxxxxxx

# Kodo 对象存储 (必需 — 项目快照与导出)
QINIU_KODO_ACCESS_KEY=xxxxxxxxxxxxxxxx
QINIU_KODO_SECRET_KEY=xxxxxxxxxxxxxxxx
QINIU_KODO_BUCKET=voicedraw-projects
QINIU_KODO_REGION=z0

# -------- 后端 --------
# FastAPI 配置
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_DEBUG=false

# CORS 允许的前端域名
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
